# Beispiel-Konfiguration. KEINE echten Geheimnisse hier ablegen — diese Datei ist im Repo.
# Echte Werte in eine lokale .env (nicht eingecheckt) bzw. als Server-Umgebungsvariablen setzen.

PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Langer Zufallswert zum Signieren der Session-Cookies (in Produktion zwingend setzen).
COOKIE_SECRET=bitte-einen-langen-zufallswert-eintragen

# MS SQL Server (bestehende Instanz im ASP-Umfeld, eigene Datenbank + eigener Benutzer).
# Wird erst genutzt, sobald die Prisma-Anbindung aktiv ist (aktuell laeuft der Server in-memory).
DATABASE_URL="sqlserver://HOST:1433;database=Zeiterfassung;user=BENUTZER;password=PASSWORT;encrypt=true;trustServerCertificate=true"

# DATEVconnect (nur auf dem ASP-Server erreichbar; localhost). Basic Auth fuer den Dienst.
DATEV_BASE_URL=http://localhost:58454/datev/api
DATEV_AUTH=basic
DATEV_USER=
DATEV_PASSWORD=
