# Beispiel-Konfiguration. KEINE echten Geheimnisse hier ablegen — diese Datei ist im Repo.
# Echte Werte in eine lokale .env (nicht eingecheckt) bzw. als Server-Umgebungsvariablen setzen.

PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Langer Zufallswert zum Signieren der Session-Cookies (in Produktion zwingend setzen).
COOKIE_SECRET=bitte-einen-langen-zufallswert-eintragen

# MS SQL Server (bestehende Instanz im ASP-Umfeld, eigene Datenbank + eigener SQL-Benutzer).
# DB_MODE: 'memory' (Default, In-Memory-Demo ohne DB) oder 'mssql' (echte Datenbank).
DB_MODE=memory
DB_HOST=
DB_PORT=1433
# Benannte Instanz statt Port (SQL Server Express installiert sich als 'SQLEXPRESS'):
DB_INSTANCE=
DB_NAME=Zeiterfassung
DB_USER=
DB_PASSWORD=
# Transportverschluesselung; bei selbstsigniertem Server-Zertifikat DB_TRUST_CERT=true lassen.
DB_ENCRYPT=true
DB_TRUST_CERT=true

# Einmalig fuer `npm run db:setup` (legt Tabellen an + ersten Admin, wenn noch keiner existiert):
# SETUP_ADMIN_USER=burchardt
# SETUP_ADMIN_NAME=O. Burchardt
# SETUP_ADMIN_EMAIL=oliver.burchardt@example.de
# SETUP_ADMIN_PASSWORD=<sicheres-Passwort>

# DATEVconnect.
# DATEV_MODE: 'mock' (Default, Schein-Adapter ohne Netz) oder 'http' (echter Zugriff).
DATEV_MODE=mock
# Basis-URL:
#   Entwicklung (lokaler PC, VPN zum ASP):  https://<interne-IP-oder-Hostname>:58452/datev/api
#   Produktion (auf dem ASP-Server):        http://localhost:58454/datev/api
DATEV_BASE_URL=http://localhost:58454/datev/api
# Anmeldung:
#   'ntlm'  = Windows-Domaenenkonto "DOMAIN\benutzer" (Entwicklungsumgebung — verifiziert)
#   'basic' = technischer Benutzer (Dauerbetrieb/Produktion)
#   'none'  = integrierte Windows-Anmeldung (nur auf dem ASP-Server selbst)
DATEV_AUTH=basic
DATEV_USER=
DATEV_PASSWORD=
# NUR Entwicklung: Zertifikatspruefung aus (Zugriff ueber IP). In Produktion verboten (Fail-Fast).
DATEV_TLS_INSECURE=false
# Optionaler OData-Filter fuer getOrders (gegen ~7.500 Auftraege), z. B. creation_year eq 2026.
DATEV_ORDERS_FILTER=
# Hartes Timeout je DATEV-Aufruf in ms (Default 30000) — haengender Dienst bindet keine Requests.
DATEV_TIMEOUT_MS=30000

# --- Automatische Synchronisierung (docs/synchronisierung-konzept.md) ---------
# Standard: an im Echtdaten-Modus (DATEV_MODE=http), aus im Mock/Demo-Modus.
# SYNC_ENABLED an  = Board liest aus dem lokalen Snapshot (sofort) statt live aus DATEV;
#                    ein Hintergrund-Job haelt den Snapshot aktuell.
SYNC_ENABLED=
# Uhrzeit des naechtlichen Voll-Laufs (24-h-Format "HH:MM").
SYNC_NIGHTLY_AT=05:00
# Abstand des Delta-Laufs tagsueber in Minuten; 0 = kein Delta (nur nachts).
SYNC_DELTA_EVERY_MIN=0
# Outbox-Arbeiter (Rueckschreibung nach DATEV): aktiv + Abstand in Minuten.
SYNC_OUTBOX_ENABLED=
SYNC_OUTBOX_EVERY_MIN=5

# ---------------------------------------------------------------------------
# Vorlage "Echtdaten lokal ansehen" (PC in der Kanzlei, VPN/Verbindung aktiv).
# Schritt-fuer-Schritt: docs/echtdaten-lokal-testen.md. Werte unten in eine
# echte, lokale .env (NICHT committen) kopieren und ausfuellen:
#
#   DATEV_MODE=http
#   DATEV_BASE_URL=https://<interne-IP-oder-Hostname>:58452/datev/api
#   DATEV_AUTH=ntlm
#   DATEV_USER=DOMAIN\benutzer
#   DATEV_PASSWORD=<Windows-Passwort>
#   DATEV_TLS_INSECURE=true
#   DATEV_ORDERS_FILTER=creation_year eq 2026
#   DB_MODE=memory
#   COOKIE_SECRET=<langer-Zufallswert>
# ---------------------------------------------------------------------------
