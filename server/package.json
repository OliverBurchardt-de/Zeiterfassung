{
  "name": "zeiterfassung-server",
  "version": "0.1.0",
  "private": true,
  "description": "Backend (M2) fuer Zeiterfassung & Auftragsabwicklung — Burchardt & Kollegen",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext ts",
    "db:setup": "tsx scripts/db-setup.ts",
    "hash-password": "tsx scripts/hash-password.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "fastify": "^4.28.1",
    "httpntlm": "^1.8.13",
    "mssql": "^11.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/mssql": "^12.3.0",
    "@types/node": "^20.14.15",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^8.57.1",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
